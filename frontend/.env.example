# Backend API Configuration
# AI Backend (TensorFlow ML + Groq API)
REACT_APP_API_BASE_URL=http://localhost:5000/api

# Main Backend (Authentication, Database, Socket.IO)
REACT_APP_API_URL=http://localhost:5001
REACT_APP_SOCKET_URL=http://localhost:5001
REACT_APP_BACKEND_URL=http://localhost:5001

# Plant.id API Configuration (Primary API for disease detection)
REACT_APP_PLANT_ID_API_KEY=your_plant_id_api_key_here

# PlantNet API Configuration (Fallback API)
REACT_APP_PLANTNET_API_KEY=your_plant_id_api_key_here
REACT_APP_PLANTNET_PROJECT=your_plant_id_api_key_here

# OpenWeather API (Already configured)
REACT_APP_OPENWEATHER_API_KEY=your_api_key_here

# Google OAuth (Optional - for social login)
REACT_APP_GOOGLE_CLIENT_ID=your_api_key_here

# Development Settings
PORT=3000
